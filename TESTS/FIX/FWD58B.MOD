MODULE Fwd58b;
VAR r: BOOLEAN;
PROCEDURE Even(n: INTEGER): BOOLEAN; FORWARD;
PROCEDURE Odd(n: INTEGER): BOOLEAN;
BEGIN
  IF n = 0 THEN RETURN FALSE END;
  RETURN Even(n - 1)
END Odd;
PROCEDURE Even;
BEGIN
  IF n = 0 THEN RETURN TRUE END;
  RETURN Odd(n - 1)
END Even;
BEGIN
  r := Even(4)
END Fwd58b.
